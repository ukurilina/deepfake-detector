# ================================
# Deepfake Detector Configuration
# ================================

# Copy this file to .env and adjust values as needed
# Do NOT commit .env to version control!

# ================================
# Server Configuration
# ================================

# Enable debug mode (development only)
DEBUG=false

# API host address
API_HOST=0.0.0.0

# API port
API_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ================================
# Model Configuration
# ================================

# Use GPU for inference (requires TensorFlow CUDA)
USE_GPU=false

# Default model name
DEFAULT_MODEL_NAME=best_model3 (3)_acc

# Maximum file size in bytes (20 MB default)
MAX_FILE_SIZE=20971520

# ================================
# Features
# ================================

# Enable video file support
ENABLE_VIDEO_SUPPORT=false

# Enable result caching with Redis
ENABLE_CACHING=false

# Enable rate limiting
ENABLE_RATE_LIMITING=false

# Cache TTL in seconds (1 hour default)
CACHE_TTL=3600

# ================================
# CORS Configuration
# ================================

# Allowed origins (comma-separated)
# Use * for all origins (development only)
CORS_ORIGINS=*

# Allow credentials
CORS_ALLOW_CREDENTIALS=true

# ================================
# Rate Limiting
# ================================

# Requests per minute (if enabled)
REQUESTS_PER_MINUTE=100

# ================================
# Database (Optional)
# ================================

# Database URL (for storing predictions history)
# Example: postgresql://user:password@localhost/deepfake_detector
# DATABASE_URL=

# ================================
# Redis (Optional)
# ================================

# Redis connection URL (for caching)
# Example: redis://localhost:6379/0
# REDIS_URL=

# ================================
# Celery (Optional)
# ================================

# Celery broker URL (for async tasks)
# Example: redis://localhost:6379/0
# CELERY_BROKER_URL=

# Celery result backend
# Example: redis://localhost:6379/0
# CELERY_RESULT_BACKEND=

# ================================
# Monitoring (Optional)
# ================================

# Prometheus metrics port (if enabled)
# PROMETHEUS_PORT=8001

# ================================
# Development
# ================================

# Enable auto-reload on code changes
RELOAD=true

# Enable testing mode
TESTING=false

# ================================
# Security (Production)
# ================================

# SSL/TLS configuration (production)
# SSL_KEYFILE=/path/to/key.pem
# SSL_CERTFILE=/path/to/cert.pem

# ================================
# Notes
# ================================

# 1. For development: use DEBUG=true and RELOAD=true
# 2. For production: use DEBUG=false and RELOAD=false
# 3. For GPU support: install tensorflow[and-cuda] and set USE_GPU=true
# 4. For caching: install redis and set ENABLE_CACHING=true
# 5. For rate limiting: install slowapi and set ENABLE_RATE_LIMITING=true
# 6. For video support: install opencv-python and set ENABLE_VIDEO_SUPPORT=true

